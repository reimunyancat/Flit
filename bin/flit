#!/usr/bin/env bash
set -euo pipefail
BASE="${FLIT_URL:-http://localhost:7777}"
AUTH=()
if [ -n "${FLIT_TOKEN:-}" ]; then AUTH=(-H "X-Flit-Token: ${FLIT_TOKEN}"); fi
post_text() { curl -fsS "${AUTH[@]}" -H "Content-Type: text/plain" --data-binary "$1" "${BASE}/api/text" >/dev/null && echo "sent text"; }
post_file() { curl -fsS "${AUTH[@]}" -F "file=@$1" "${BASE}/api/file" >/dev/null && echo "sent $1"; }
if [ "$#" -eq 0 ]; then PIPED="$(cat)"; [ -n "$PIPED" ] && post_text "$PIPED"; exit 0; fi
for arg in "$@"; do if [ -f "$arg" ]; then post_file "$arg"; else post_text "$arg"; fi; done